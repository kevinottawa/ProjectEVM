+    void prepare_gpu_page_mapping(int count) {
+        std::lock_guard<std::mutex> lock(mtx);
+        ensure_physical_ids_capacity_locked(count);
+    }
+
+    void record_gpu_page_hit(uint64_t active_mask, int count, cudaStream_t compute_stream) {
+        std::lock_guard<std::mutex> lock(mtx);
+        CUDA_CHECK(cudaEventRecord(pool_reuse_event, compute_stream));
+        CUDA_CHECK(cudaStreamWaitEvent(stream, pool_reuse_event, 0));
+        std::vector<int> current_ids;
+        for (int logical = 0; logical < total_experts; ++logical) {
+            if ((active_mask & (UINT64_C(1) << logical)) == 0) continue;
+            const auto it = cache_map.find(logical);
+            if (it == cache_map.end()) {
+                // A stale table is treated as a miss by the caller. This guard
+                // keeps the cache state conservative if a future caller races.
+                return;
+            }
+            const int physical = *(it->second);
+            lru_list.erase(it->second);
+            lru_list.push_front(physical);
+            cache_map[logical] = lru_list.begin();
+            expert_access_counts[(size_t) logical]++;
+            current_ids.push_back(logical);
+        }
+        if (metrics_enabled) metric_cache_hits += (uint64_t) count;
+        metric_gpu_page_hits++;
+        last_routed_experts = current_ids;
+        queue_predictive_prefetch_locked(current_ids);
+        sync_gpu_page_table_locked();
+        cudaEventRecord(event, stream);
+        cudaStreamWaitEvent(compute_stream, event, 0);
+    }
+
+    void record_gpu_page_miss() {
+        std::lock_guard<std::mutex> lock(mtx);
+        metric_gpu_page_misses++;
+    }
+
+    void record_gpu_page_attempt() {
+        std::lock_guard<std::mutex> lock(mtx);
+        metric_gpu_page_attempts++;
+    }
 
