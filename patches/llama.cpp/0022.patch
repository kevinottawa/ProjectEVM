 }
 
+// Cache-hit remapping is a tiny GPU operation.  The output is contiguous even
+// when the logical ID view has a row stride, matching the replacement view
+// used by mul_mat_id below.  A 64-bit activity mask is enough for the current
+// EVM model families (60 or 64 experts); a nonzero miss flag requests the
+// existing exact host service path before any expert kernel is dispatched.
+static __global__ void ggml_cuda_evm_map_ids_kernel(
+        const char * logical_ids,
+        size_t logical_row_stride,
+        int ids_per_token,
+        int count,
+        const int * page_table,
+        int total_experts,
+        int * physical_ids,
+        unsigned long long * status) {
+    const int index = blockIdx.x * blockDim.x + threadIdx.x;
+    if (index >= count) return;
+    const int row = index / ids_per_token;
+    const int col = index - row * ids_per_token;
+    const int logical = *(const int *) (logical_ids + (size_t) row * logical_row_stride + (size_t) col * sizeof(int));
+    if (logical < 0) {
+        physical_ids[index] = logical;
+        return;
+    }
+    if (logical >= total_experts) {
+        atomicExch((unsigned long long *) &status[1], 1ULL);
+        return;
+    }
+    atomicOr(&status[0], UINT64_C(1) << logical);
+    const int physical = page_table[logical];
+    if (physical < 0) {
+        atomicExch((unsigned long long *) &status[1], 1ULL);
+        return;
+    }
+    physical_ids[index] = physical;
+}
+
+static bool ggml_cuda_evm_try_gpu_page_remap(
+        ggml_backend_cuda_context & ctx,
+        const ggml_tensor * ids,
+        EVM::Manager * mgr,
+        int count) {
+    mgr->record_gpu_page_attempt();
+    if (!mgr->gpu_page_table_enabled() || ids->ne[0] <= 0 || count <= 0) {
+        return false;
+    }
+    mgr->prepare_gpu_page_mapping(count);
+    CUDA_CHECK(cudaMemsetAsync(mgr->get_page_status(), 0, 2 * sizeof(unsigned long long), ctx.stream()));
+    const int threads = 256;
+    const int blocks = (count + threads - 1) / threads;
+    ggml_cuda_evm_map_ids_kernel<<<blocks, threads, 0, ctx.stream()>>>(
+        (const char *) ids->data,
+        ids->nb[1],
+        (int) ids->ne[0],
+        count,
+        mgr->get_page_table(),
+        mgr->get_total_experts(),
+        mgr->get_physical_ids(),
+        mgr->get_page_status());
+    CUDA_CHECK(cudaGetLastError());
+    CUDA_CHECK(cudaMemcpyAsync(
+        mgr->get_host_page_status(),
+        mgr->get_page_status(),
+        2 * sizeof(unsigned long long),
+        cudaMemcpyDeviceToHost,
+        ctx.stream()));
+    CUDA_CHECK(cudaStreamSynchronize(ctx.stream()));
+    const unsigned long long * status = mgr->get_host_page_status();
+    if (status[1] != 0) {
+        mgr->record_gpu_page_miss();
+        return false;
+    }
+    mgr->record_gpu_page_hit(status[0], count, ctx.stream());
+    return true;
+}
