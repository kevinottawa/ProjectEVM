From 08c0472a942331009a8c342853c856d3a7fbaed3 Mon Sep 17 00:00:00 2001
From: kevinottawa <69475646+kevinottawa@users.noreply.github.com>
Date: Tue, 14 Jul 2026 19:03:07 -0400
Subject: [PATCH 25/26] Prototype learned router-score EVM eviction

---
 ggml/src/ggml-cuda/evm.cuh      | 49 ++++++++++++++++++++++++++++++++-
 ggml/src/ggml-cuda/ggml-cuda.cu | 14 ++++++++--
 2 files changed, 60 insertions(+), 3 deletions(-)

diff --git a/ggml/src/ggml-cuda/evm.cuh b/ggml/src/ggml-cuda/evm.cuh
index 3aa8465d1..604a4bb4d 100644
--- a/ggml/src/ggml-cuda/evm.cuh
+++ b/ggml/src/ggml-cuda/evm.cuh
@@ -358,6 +358,7 @@ private:
     int* h_router_candidates = nullptr;
     float* d_router_candidate_scores = nullptr;
     float* h_router_candidate_scores = nullptr;
+    float* d_learned_router_weights = nullptr;
     int* h_physical_ids[2] = {nullptr, nullptr};
     cudaEvent_t physical_ids_events[2] = {nullptr, nullptr};
     bool physical_ids_event_recorded[2] = {false, false};
@@ -380,6 +381,7 @@ private:
     std::vector<CacheSlot> slots;
     std::vector<uint64_t> transition_counts;
     std::vector<int> last_routed_experts;
+    std::vector<float> future_expert_scores;
     std::unordered_set<int> prefetched_experts;
     
     bool initialized = false;
@@ -462,6 +464,7 @@ public:
         if (d_page_status) cudaFree(d_page_status);
         if (d_router_candidates) cudaFree(d_router_candidates);
         if (d_router_candidate_scores) cudaFree(d_router_candidate_scores);
+        if (d_learned_router_weights) cudaFree(d_learned_router_weights);
         if (h_page_table) cudaFreeHost(h_page_table);
         if (h_page_status) cudaFreeHost(h_page_status);
         if (h_router_candidates) cudaFreeHost(h_router_candidates);
@@ -524,7 +527,24 @@ public:
     }
 
     std::list<int>::iterator learned_eviction_candidate(const std::unordered_set<int> & protected_ids) {
-        if (read_env_ll("EVM_LEARNED_SCHEDULER", 0) == 0) return eviction_candidate(protected_ids);
+        if (read_env_ll("EVM_LEARNED_SCHEDULER", 0) == 0 && read_env_ll("EVM_LEARNED_ROUTER_SCORE", 0) == 0) {
+            return eviction_candidate(protected_ids);
+        }
+        if (read_env_ll("EVM_LEARNED_ROUTER_SCORE", 0) != 0 && future_expert_scores.size() == (size_t) total_experts) {
+            auto selected = lru_list.end();
+            float selected_score = 0.0f;
+            for (auto it = lru_list.begin(); it != lru_list.end(); ++it) {
+                if (is_predictive_slot(*it)) continue;
+                const int logical = slots[*it].logical_expert_id;
+                if (logical >= 0 && (pinned_experts.find(logical) != pinned_experts.end() || protected_ids.find(logical) != protected_ids.end())) continue;
+                const float score = logical >= 0 ? future_expert_scores[(size_t) logical] : -1.0f;
+                if (selected == lru_list.end() || score <= selected_score) {
+                    selected = it;
+                    selected_score = score;
+                }
+            }
+            if (selected != lru_list.end()) return selected;
+        }
         const auto * matrix = learned_prior_registry().matrix(layer_index, total_experts);
         if (!matrix || last_routed_experts.empty()) return eviction_candidate(protected_ids);
         std::vector<float> scores((size_t) total_experts, 0.0f);
@@ -1276,6 +1296,24 @@ public:
     float* get_router_candidate_scores_host() { return h_router_candidate_scores; }
     int get_total_experts() const { return total_experts; }
 
+    // The offline model predicts the next 3--17 tokens from the complete
+    // current router vector. Keep its tiny layer matrix on-device so the
+    // host receives only the top candidate IDs, never a full score vector.
+    const float * get_learned_router_weights_device() {
+        if (read_env_ll("EVM_LEARNED_ROUTER_SCORE", 0) == 0) return nullptr;
+        std::lock_guard<std::mutex> lock(mtx);
+        if (d_learned_router_weights) return d_learned_router_weights;
+        const auto * matrix = learned_prior_registry().matrix(layer_index, total_experts);
+        if (!matrix) return nullptr;
+        CUDA_CHECK(cudaMalloc(&d_learned_router_weights, matrix->size() * sizeof(float)));
+        CUDA_CHECK(cudaMemcpy(
+            d_learned_router_weights,
+            matrix->data(),
+            matrix->size() * sizeof(float),
+            cudaMemcpyHostToDevice));
+        return d_learned_router_weights;
+    }
+
     bool gpu_page_table_enabled() const {
         return initialized && total_experts <= 64 && read_env_ll("EVM_GPU_PAGE_TABLE", 0) != 0;
     }
@@ -1327,6 +1365,15 @@ public:
     void queue_router_score_prefetch(const std::vector<int> & candidates, const std::vector<float> & candidate_scores, const int * logical_ids, int count) {
         if (candidates.empty() || candidate_scores.size() != candidates.size() || !logical_ids || count <= 0) return;
         std::lock_guard<std::mutex> lock(mtx);
+        if (read_env_ll("EVM_LEARNED_ROUTER_SCORE", 0) != 0) {
+            future_expert_scores.assign((size_t) total_experts, 0.0f);
+            for (size_t index = 0; index < candidates.size(); ++index) {
+                const int expert = candidates[index];
+                if (expert >= 0 && expert < total_experts) {
+                    future_expert_scores[(size_t) expert] = candidate_scores[index];
+                }
+            }
+        }
         std::unordered_set<int> current_ids;
         for (int i = 0; i < count; ++i) {
             if (logical_ids[i] >= 0 && logical_ids[i] < total_experts) current_ids.insert(logical_ids[i]);
diff --git a/ggml/src/ggml-cuda/ggml-cuda.cu b/ggml/src/ggml-cuda/ggml-cuda.cu
index 9162c3bc8..b40a0e84c 100644
--- a/ggml/src/ggml-cuda/ggml-cuda.cu
+++ b/ggml/src/ggml-cuda/ggml-cuda.cu
@@ -1837,6 +1837,7 @@ static std::vector<int> ggml_cuda_evm_copy_ids_to_host(
 
 static __global__ void ggml_cuda_evm_rank_router_candidates_kernel(
         const float * scores,
+        const float * learned_weights,
         int total_experts,
         int candidate_count,
         int * candidates,
@@ -1847,8 +1848,15 @@ static __global__ void ggml_cuda_evm_rank_router_candidates_kernel(
         float best = -INFINITY;
         int best_expert = -1;
         for (int expert = 0; expert < total_experts; ++expert) {
-            if (!chosen[expert] && scores[expert] > best) {
-                best = scores[expert];
+            float candidate_score = scores[expert];
+            if (learned_weights) {
+                candidate_score = 0.0f;
+                for (int source = 0; source < total_experts; ++source) {
+                    candidate_score += scores[source] * learned_weights[source * total_experts + expert];
+                }
+            }
+            if (!chosen[expert] && candidate_score > best) {
+                best = candidate_score;
                 best_expert = expert;
             }
         }
@@ -1885,8 +1893,10 @@ static ggml_cuda_evm_router_candidates ggml_cuda_evm_copy_router_candidates_to_h
         candidate_count = std::max(1, std::min(8, atoi(value)));
     }
     const int64_t row = scores->ne[1] - 1;
+    const float * learned_weights = mgr->get_learned_router_weights_device();
     ggml_cuda_evm_rank_router_candidates_kernel<<<1, 1, 0, ctx.stream()>>>(
         (const float *) ((const char *) scores->data + (size_t) row * scores->nb[1]),
+        learned_weights,
         total_experts,
         candidate_count,
         mgr->get_router_candidates_device(),
