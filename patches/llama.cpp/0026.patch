diff --git a/ggml/src/ggml-cuda/ggml-cuda.cu b/ggml/src/ggml-cuda/ggml-cuda.cu
index b40a0e84c..3beaf9d87 100644
--- a/ggml/src/ggml-cuda/ggml-cuda.cu
+++ b/ggml/src/ggml-cuda/ggml-cuda.cu
@@ -1866,6 +1866,24 @@ static __global__ void ggml_cuda_evm_rank_router_candidates_kernel(
     }
 }
 
+static __global__ void ggml_cuda_evm_update_future_scores_kernel(
+        const float * scores,
+        const float * learned_weights,
+        int total_experts,
+        float * future_scores) {
+    if (blockIdx.x != 0 || threadIdx.x != 0) return;
+    for (int expert = 0; expert < total_experts; ++expert) {
+        float score = scores[expert];
+        if (learned_weights) {
+            score = 0.0f;
+            for (int source = 0; source < total_experts; ++source) {
+                score += scores[source] * learned_weights[source * total_experts + expert];
+            }
+        }
+        future_scores[expert] = fmaxf(0.0f, score);
+    }
+}
+
 struct ggml_cuda_evm_router_candidates {
     std::vector<int> ids;
     std::vector<float> scores;
@@ -1921,6 +1939,45 @@ static ggml_cuda_evm_router_candidates ggml_cuda_evm_copy_router_candidates_to_h
     };
 }
 
+static bool ggml_cuda_evm_update_future_scores(
+        ggml_backend_cuda_context & ctx,
+        const ggml_tensor * ids,
+        EVM::Manager * mgr) {
+    if (!mgr->gpu_scheduler_enabled()) return false;
+    const int total_experts = mgr->get_total_experts();
+    if (total_experts > 64) return false;
+    const ggml_tensor * scores = ids ? ids->src[0] : nullptr;
+    while (scores && (scores->op == GGML_OP_VIEW || scores->op == GGML_OP_RESHAPE ||
+            scores->op == GGML_OP_CONT || scores->op == GGML_OP_ARGSORT)) {
+        scores = scores->src[0];
+    }
+    if (!scores || scores->type != GGML_TYPE_F32 || scores->ne[0] != total_experts || scores->ne[1] <= 0 || !scores->data) {
+        return false;
+    }
+    const int64_t row = scores->ne[1] - 1;
+    ggml_cuda_evm_update_future_scores_kernel<<<1, 1, 0, ctx.stream()>>>(
+        (const float *) ((const char *) scores->data + (size_t) row * scores->nb[1]),
+        mgr->get_learned_router_weights_device(),
+        total_experts,
+        mgr->get_future_expert_scores_device());
+    CUDA_CHECK(cudaGetLastError());
+    return true;
+}
+
+static void ggml_cuda_evm_copy_future_scores_to_host(
+        ggml_backend_cuda_context & ctx,
+        EVM::Manager * mgr) {
+    if (!mgr->gpu_scheduler_enabled()) return;
+    CUDA_CHECK(cudaMemcpyAsync(
+        mgr->get_future_expert_scores_host(),
+        mgr->get_future_expert_scores_device(),
+        (size_t) mgr->get_total_experts() * sizeof(float),
+        cudaMemcpyDeviceToHost,
+        ctx.stream()));
+    CUDA_CHECK(cudaStreamSynchronize(ctx.stream()));
+    mgr->update_future_expert_scores(mgr->get_future_expert_scores_host());
+}
+
 // Cache-hit remapping is a tiny GPU operation.  The output is contiguous even
 // when the logical ID view has a row stride, matching the replacement view
 // used by mul_mat_id below.  A 64-bit activity mask is enough for the current
@@ -1989,6 +2046,7 @@ static bool ggml_cuda_evm_try_gpu_page_remap(
     CUDA_CHECK(cudaStreamSynchronize(ctx.stream()));
     const unsigned long long * status = mgr->get_host_page_status();
     if (status[1] != 0) {
+        ggml_cuda_evm_copy_future_scores_to_host(ctx, mgr);
         mgr->record_gpu_page_miss();
         return false;
     }
@@ -2059,9 +2117,14 @@ static bool ggml_cuda_evm_remap_mul_mat_id(
     int count = 0;
     mgr->update_phase(ids->ne[1]);
     count = (int) (ids->ne[0] * ids->ne[1]);
+    const bool gpu_scheduler = ggml_cuda_evm_update_future_scores(ctx, ids, mgr);
+    const bool gpu_page_table = mgr->gpu_page_table_enabled();
     if (!ggml_cuda_evm_try_gpu_page_remap(ctx, ids, mgr, count)) {
         std::vector<int> h_ids = ggml_cuda_evm_copy_ids_to_host(ctx, ids, count);
         const std::vector<int> logical_ids = h_ids;
+        if (gpu_scheduler && !gpu_page_table) {
+            ggml_cuda_evm_copy_future_scores_to_host(ctx, mgr);
+        }
         const ggml_cuda_evm_router_candidates router_candidates = ggml_cuda_evm_copy_router_candidates_to_host(ctx, ids, mgr);
         if (getenv("EVM_ROUTER_SCORE_PREFETCH") != nullptr && atoi(getenv("EVM_ROUTER_SCORE_PREFETCH")) != 0) {
             mgr->note_router_score_bridge(!router_candidates.ids.empty());
