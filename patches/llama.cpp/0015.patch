diff --git a/ggml/src/ggml-cuda/evm.cuh b/ggml/src/ggml-cuda/evm.cuh
index 660360dbc..f455b8577 100644
--- a/ggml/src/ggml-cuda/evm.cuh
+++ b/ggml/src/ggml-cuda/evm.cuh
@@ -887,6 +887,31 @@ public:
     
     char* get_pool() { return d_pool; }
     int* get_physical_ids() { return d_physical_ids; }
+
+    void write_profile(std::ofstream & profile, const char * prompt_id, const char * phase) {
+        std::lock_guard<std::mutex> lock(mtx);
+        profile << "{\"prompt_id\":\"" << prompt_id << "\",\"phase\":\"" << phase
+                << "\",\"tensor\":\"" << vault_tensor_name << "\",\"counts\":[";
+        for (size_t i = 0; i < expert_access_counts.size(); ++i) {
+            if (i) profile << ',';
+            profile << expert_access_counts[i];
+        }
+        profile << "]}\n";
+    }
+
+    void reset_observation(bool reset_expert_cache) {
+        std::lock_guard<std::mutex> lock(mtx);
+        std::fill(expert_access_counts.begin(), expert_access_counts.end(), 0);
+        metric_cache_hits = 0;
+        metric_cache_misses = 0;
+        metric_evictions = 0;
+        metric_bytes_transferred = 0;
+        metric_pack_substitutions = 0;
+        if (reset_expert_cache && !ability_pack_only) {
+            reset_cache_state();
+            if (ability_enabled) preload_ability_experts();
+        }
+    }
 };
 
 inline std::unordered_map<const ggml_tensor*, std::shared_ptr<Manager>>& get_managers_map() {
@@ -941,6 +966,26 @@ inline void print_all_stats() {
     fflush(stderr);
 }
 
+inline bool write_profile_snapshot(const char * path, const char * prompt_id, const char * phase, bool reset_counters) {
+    if (!path || !*path || !prompt_id || !phase) return false;
+    std::lock_guard<std::mutex> lock(get_managers_mutex());
+    std::ofstream profile(path, std::ios::app);
+    if (!profile) return false;
+    for (auto & pair : get_managers_map()) {
+        if (!pair.second) continue;
+        pair.second->write_profile(profile, prompt_id, phase);
+        if (reset_counters) pair.second->reset_observation(false);
+    }
+    return profile.good();
+}
+
+inline void reset_all(bool reset_expert_cache) {
+    std::lock_guard<std::mutex> lock(get_managers_mutex());
+    for (auto & pair : get_managers_map()) {
+        if (pair.second) pair.second->reset_observation(reset_expert_cache);
+    }
+}
+
 inline Manager* get_manager(const ggml_tensor* t) {
     auto& managers = get_managers_map();
     std::lock_guard<std::mutex> lock(get_managers_mutex());
