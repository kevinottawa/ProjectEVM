From c4b535ee7d341db18f68b5b3052ce29243d58600 Mon Sep 17 00:00:00 2001
From: kevinottawa <69475646+kevinottawa@users.noreply.github.com>
Date: Thu, 9 Jul 2026 17:41:02 -0400
Subject: [PATCH 05/26] Harden EVM remap diagnostics and id buffers

---
 ggml/src/ggml-cuda/evm.cuh      | 54 ++++++++++++++++++++++++----
 ggml/src/ggml-cuda/ggml-cuda.cu | 62 ++++++++++++++++++++++++++++++---
 2 files changed, 105 insertions(+), 11 deletions(-)

diff --git a/ggml/src/ggml-cuda/evm.cuh b/ggml/src/ggml-cuda/evm.cuh
index 4e76e8a00..1a19a1671 100644
--- a/ggml/src/ggml-cuda/evm.cuh
+++ b/ggml/src/ggml-cuda/evm.cuh
@@ -30,6 +30,7 @@ private:
     char* d_pool = nullptr;
     char* h_experts_mmap = nullptr;
     int* d_physical_ids = nullptr;
+    int d_physical_ids_capacity = 0;
     bool source_on_device = false;
     
     cudaStream_t stream;
@@ -115,6 +116,27 @@ public:
         reset_cache_state();
     }
 
+    void ensure_physical_ids_capacity_locked(int count) {
+        if (count <= d_physical_ids_capacity) {
+            return;
+        }
+        int new_capacity = std::max(1, d_physical_ids_capacity);
+        while (new_capacity < count) {
+            new_capacity *= 2;
+        }
+        int * new_ids = nullptr;
+        CUDA_CHECK(cudaMalloc(&new_ids, (size_t)new_capacity * sizeof(int)));
+        CUDA_CHECK(cudaMemset(new_ids, 0, (size_t)new_capacity * sizeof(int)));
+        if (d_physical_ids) {
+            cudaFree(d_physical_ids);
+        }
+        d_physical_ids = new_ids;
+        d_physical_ids_capacity = new_capacity;
+        if (getenv("EVM_DEBUG")) {
+            fprintf(stderr, "EVM: resized physical id buffer to %d entries\n", d_physical_ids_capacity);
+        }
+    }
+
 public:
     void init(int num_experts_capacity, int bytes_per_expert, char* original_d_ptr, int num_total_experts) {
         std::lock_guard<std::mutex> lock(mtx);
@@ -152,8 +174,7 @@ public:
         }
         capacity = requested_capacity;
         CUDA_CHECK(cudaMalloc(&d_pool, (size_t)capacity * expert_size_bytes));
-        CUDA_CHECK(cudaMalloc(&d_physical_ids, 65536 * sizeof(int))); // Max 65536 ids for large batches
-        CUDA_CHECK(cudaMemset(d_physical_ids, 0, 65536 * sizeof(int)));
+        ensure_physical_ids_capacity_locked((int) read_env_ll("EVM_ID_BUFFER_CAPACITY", 65536));
 
         h_experts_mmap = original_d_ptr;
         cudaPointerAttributes attr;
@@ -228,6 +249,12 @@ public:
         std::unordered_set<int> unique_ids;
         for (int i = 0; i < count; ++i) {
             if (logical_ids[i] >= 0) {
+                if (logical_ids[i] >= total_experts) {
+                    fprintf(stderr,
+                            "EVM: invalid logical expert id %d for tensor with %d experts\n",
+                            logical_ids[i], total_experts);
+                    abort();
+                }
                 unique_ids.insert(logical_ids[i]);
             }
         }
@@ -236,14 +263,11 @@ public:
         }
 
         bool needs_sync = false;
+        ensure_physical_ids_capacity_locked(count);
         
         for (int i = 0; i < count; ++i) {
             int log_id = logical_ids[i];
             if (log_id < 0) continue;
-            if (log_id >= 2048) {
-                fprintf(stderr, "EVM: ignoring out-of-range logical expert id %d\n", log_id);
-                continue;
-            }
             
             auto it = cache_map.find(log_id);
             if (it != cache_map.end()) {
@@ -283,6 +307,24 @@ public:
                 logical_ids[i] = phys_idx;
             }
         }
+
+        int min_physical = capacity;
+        int max_physical = -1;
+        for (int i = 0; i < count; ++i) {
+            if (logical_ids[i] < 0 || logical_ids[i] >= capacity) {
+                fprintf(stderr,
+                        "EVM: invalid remapped physical expert id %d for capacity %d\n",
+                        logical_ids[i], capacity);
+                abort();
+            }
+            min_physical = std::min(min_physical, logical_ids[i]);
+            max_physical = std::max(max_physical, logical_ids[i]);
+        }
+        if (getenv("EVM_DEBUG")) {
+            fprintf(stderr,
+                    "EVM: remapped %d ids to physical range [%d,%d] capacity=%d unique=%zu\n",
+                    count, min_physical, max_physical, capacity, unique_ids.size());
+        }
         
         // Now it's safe to overwrite d_physical_ids because compute_stream is idle
         // Use synchronous cudaMemcpy so logical_ids (h_ids vector) doesn't go out of scope!
diff --git a/ggml/src/ggml-cuda/ggml-cuda.cu b/ggml/src/ggml-cuda/ggml-cuda.cu
index 69954bb0b..adc412af2 100644
--- a/ggml/src/ggml-cuda/ggml-cuda.cu
+++ b/ggml/src/ggml-cuda/ggml-cuda.cu
@@ -1763,10 +1763,9 @@ static void ggml_cuda_mul_mat_id(ggml_backend_cuda_context & ctx, ggml_tensor *
     GGML_ASSERT(src1->type == GGML_TYPE_F32);
     GGML_ASSERT(dst->type  == GGML_TYPE_F32);
 
-    GGML_TENSOR_BINARY_OP_LOCALS
-    
     ggml_tensor ids_copy;
     ggml_tensor src0_copy;
+    bool evm_remapped = false;
 
     // EVM Interception: Check if this is an MoE layer
     static int ignore_count = -1;
@@ -1799,6 +1798,22 @@ static void ggml_cuda_mul_mat_id(ggml_backend_cuda_context & ctx, ggml_tensor *
                     (long long) src0->ne[2],
                     ids ? (long long) ids->ne[0] : 0,
                     ids ? (long long) ids->ne[1] : 0);
+            fprintf(stderr,
+                    "EVM: src0 name=%s type=%d ne=[%lld,%lld,%lld,%lld] nb=[%zu,%zu,%zu,%zu] ids nb=[%zu,%zu,%zu,%zu]\n",
+                    src0->name,
+                    (int) src0->type,
+                    (long long) src0->ne[0],
+                    (long long) src0->ne[1],
+                    (long long) src0->ne[2],
+                    (long long) src0->ne[3],
+                    src0->nb[0],
+                    src0->nb[1],
+                    src0->nb[2],
+                    src0->nb[3],
+                    ids->nb[0],
+                    ids->nb[1],
+                    ids->nb[2],
+                    ids->nb[3]);
         }
         EVM::Manager* mgr = EVM::get_manager(src0);
         if (!mgr->is_initialized()) {
@@ -1822,11 +1837,11 @@ static void ggml_cuda_mul_mat_id(ggml_backend_cuda_context & ctx, ggml_tensor *
         size_t count = ids->ne[0] * ids->ne[1];
         std::vector<int> h_ids(count);
         if (ids->nb[1] == ids->ne[0] * sizeof(int)) {
-            cudaMemcpyAsync(h_ids.data(), ids->data, count * sizeof(int), cudaMemcpyDeviceToHost, ctx.stream());
+            CUDA_CHECK(cudaMemcpyAsync(h_ids.data(), ids->data, count * sizeof(int), cudaMemcpyDeviceToHost, ctx.stream()));
         } else {
-            cudaMemcpy2DAsync(h_ids.data(), ids->ne[0] * sizeof(int), ids->data, ids->nb[1], ids->ne[0] * sizeof(int), ids->ne[1], cudaMemcpyDeviceToHost, ctx.stream());
+            CUDA_CHECK(cudaMemcpy2DAsync(h_ids.data(), ids->ne[0] * sizeof(int), ids->data, ids->nb[1], ids->ne[0] * sizeof(int), ids->ne[1], cudaMemcpyDeviceToHost, ctx.stream()));
         }
-        cudaStreamSynchronize(ctx.stream());
+        CUDA_CHECK(cudaStreamSynchronize(ctx.stream()));
         
         mgr->update_phase(ids->ne[1]);
         mgr->ensure_experts(h_ids.data(), count, ctx.stream());
@@ -1844,9 +1859,30 @@ static void ggml_cuda_mul_mat_id(ggml_backend_cuda_context & ctx, ggml_tensor *
         src0_copy.buffer = nullptr;
         src0_copy.ne[2] = mgr->get_capacity();
         src0 = &src0_copy;
+        evm_remapped = true;
     }
 
+    GGML_TENSOR_BINARY_OP_LOCALS
+
     const int cc = ggml_cuda_info().devices[ggml_cuda_get_device()].cc;
+    if (evm_remapped && getenv("EVM_DEBUG")) {
+        fprintf(stderr,
+                "EVM: remapped mul_mat_id locals dst_ne=[%lld,%lld,%lld,%lld] src1_ne=[%lld,%lld,%lld,%lld] "
+                "ne2=%lld ne02=%lld ne12=%lld mmvq_max=%d capacity=%lld\n",
+                (long long) dst->ne[0],
+                (long long) dst->ne[1],
+                (long long) dst->ne[2],
+                (long long) dst->ne[3],
+                (long long) src1->ne[0],
+                (long long) src1->ne[1],
+                (long long) src1->ne[2],
+                (long long) src1->ne[3],
+                (long long) ne2,
+                (long long) ne02,
+                (long long) ne12,
+                get_mmvq_mmid_max_batch(src0->type, cc),
+                (long long) src0->ne[2]);
+    }
 
     // [TAG_MUL_MAT_ID_CUDA_GRAPHS]
     if (src1->type == GGML_TYPE_F32 && dst->type == GGML_TYPE_F32) {
@@ -1855,21 +1891,37 @@ static void ggml_cuda_mul_mat_id(ggml_backend_cuda_context & ctx, ggml_tensor *
             if (ggml_is_quantized(src0->type)) {
                 const int mmvq_mmid_max = get_mmvq_mmid_max_batch(src0->type, cc);
                 if (ne2 <= mmvq_mmid_max) {
+                    if (evm_remapped && getenv("EVM_DEBUG")) {
+                        fprintf(stderr, "EVM: route=mmvq type=%d ne2=%lld ne12=%lld ne02=%lld\n",
+                                (int) src0->type, (long long) ne2, (long long) ne12, (long long) ne02);
+                    }
                     ggml_cuda_mul_mat_vec_q(ctx, src0, src1, ids, dst);
                     return;
                 }
             } else {
+                if (evm_remapped && getenv("EVM_DEBUG")) {
+                    fprintf(stderr, "EVM: route=mmvf ne2=%lld ne12=%lld ne02=%lld\n",
+                            (long long) ne2, (long long) ne12, (long long) ne02);
+                }
                 ggml_cuda_mul_mat_vec_f(ctx, src0, src1, ids, dst);
                 return;
             }
         }
 
         if (ggml_cuda_should_use_mmq(src0->type, cc, ne12, /*n_experts=*/ne02)) {
+            if (evm_remapped && getenv("EVM_DEBUG")) {
+                fprintf(stderr, "EVM: route=mmq type=%d ne2=%lld ne12=%lld ne02=%lld\n",
+                        (int) src0->type, (long long) ne2, (long long) ne12, (long long) ne02);
+            }
             ggml_cuda_mul_mat_q(ctx, src0, src1, ids, dst);
             return;
         }
 
         if (ggml_cuda_should_use_mmf(src0->type, cc, WARP_SIZE, src0->ne, src0->nb, src1->ne[2], /*mul_mat_id=*/true)) {
+            if (evm_remapped && getenv("EVM_DEBUG")) {
+                fprintf(stderr, "EVM: route=mmf type=%d ne2=%lld ne12=%lld ne02=%lld\n",
+                        (int) src0->type, (long long) ne2, (long long) ne12, (long long) ne02);
+            }
             ggml_cuda_mul_mat_f(ctx, src0, src1, ids, dst);
             return;
         }
