+static EVM::Manager * ggml_cuda_evm_get_or_init_manager(const ggml_tensor * src0) {
+    EVM::Manager * mgr = EVM::get_manager(src0);
+    if (!mgr->is_initialized()) {
+        const int total_experts = src0->ne[2];
+        const int expert_size = src0->nb[2];
+        mgr->init(ggml_cuda_evm_capacity_for_total(total_experts), expert_size, (char *) src0->data, total_experts);
+    }
+    return mgr;
+}
