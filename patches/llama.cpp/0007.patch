+    void ensure_experts_with_fixed_mapping(
+            const int * logical_ids,
+            int * physical_ids,
+            int count,
+            const std::unordered_map<int, int> & logical_to_physical,
+            cudaStream_t compute_stream) {
+        if (!is_initialized()) return;
+        std::lock_guard<std::mutex> lock(mtx);
+
+        CUDA_CHECK(cudaStreamSynchronize(compute_stream));
+
+        if ((int) logical_to_physical.size() > capacity) {
+            resize_pool_locked((int) logical_to_physical.size());
+        }
+
+        bool needs_sync = false;
+        ensure_physical_ids_capacity_locked(count);
+
+        for (const auto & pair : logical_to_physical) {
+            const int log_id = pair.first;
+            const int phys_idx = pair.second;
+
+            if (log_id < 0 || log_id >= total_experts) {
+                fprintf(stderr,
+                        "EVM: invalid logical expert id %d for tensor with %d experts\n",
+                        log_id, total_experts);
+                abort();
+            }
+            if (phys_idx < 0 || phys_idx >= capacity) {
+                fprintf(stderr,
+                        "EVM: invalid fixed physical expert id %d for capacity %d\n",
+                        phys_idx, capacity);
+                abort();
+            }
+
+            if (slots[phys_idx].logical_expert_id == log_id) {
+                metric_cache_hits++;
+                continue;
+            }
+
+            metric_cache_misses++;
+
+            const int old_log_at_phys = slots[phys_idx].logical_expert_id;
+            if (old_log_at_phys != -1) {
+                metric_evictions++;
+            }
+
+            for (auto & slot : slots) {
+                if (slot.physical_index != phys_idx && slot.logical_expert_id == log_id) {
+                    slot.logical_expert_id = -1;
+                    break;
+                }
+            }
+
+            slots[phys_idx].logical_expert_id = log_id;
+
+            const size_t offset = (size_t) log_id * expert_size_bytes;
+            const size_t dst_offset = (size_t) phys_idx * expert_size_bytes;
+
+            CUDA_CHECK(cudaMemcpyAsync(
+                d_pool + dst_offset,
+                h_experts_mmap + offset,
+                expert_size_bytes,
+                source_on_device ? cudaMemcpyDeviceToDevice : cudaMemcpyHostToDevice,
+                stream));
+            metric_bytes_transferred += expert_size_bytes;
+            needs_sync = true;
+        }
+
+        cache_map.clear();
+        lru_list.clear();
+        std::unordered_set<int> mapped_phys;
+        for (const auto & pair : logical_to_physical) {
+            mapped_phys.insert(pair.second);
+        }
+        for (const auto & pair : logical_to_physical) {
+            const int phys_idx = pair.second;
+            lru_list.push_front(phys_idx);
+            cache_map[slots[phys_idx].logical_expert_id] = lru_list.begin();
+        }
+        for (const auto & slot : slots) {
+            if (mapped_phys.find(slot.physical_index) != mapped_phys.end()) {
+                continue;
+            }
+            lru_list.push_back(slot.physical_index);
+            if (slot.logical_expert_id != -1) {
+                auto it = lru_list.end();
+                --it;
+                cache_map[slot.logical_expert_id] = it;
+            }
+        }
+
+        int min_physical = capacity;
+        int max_physical = -1;
+        for (int i = 0; i < count; ++i) {
+            const int log_id = logical_ids[i];
+            if (log_id < 0) {
+                physical_ids[i] = log_id;
+                continue;
+            }
+            auto it = logical_to_physical.find(log_id);
+            if (it == logical_to_physical.end()) {
+                fprintf(stderr, "EVM: missing fixed mapping for logical expert id %d\n", log_id);
+                abort();
+            }
+            physical_ids[i] = it->second;
+            min_physical = std::min(min_physical, physical_ids[i]);
+            max_physical = std::max(max_physical, physical_ids[i]);
+        }
+        if (getenv("EVM_DEBUG")) {
+            fprintf(stderr,
+                    "EVM: fixed-remapped %d ids to physical range [%d,%d] capacity=%d unique=%zu\n",
+                    count, min_physical, max_physical, capacity, logical_to_physical.size());
+        }
+
+        CUDA_CHECK(cudaMemcpy(d_physical_ids, physical_ids, count * sizeof(int), cudaMemcpyHostToDevice));
+        needs_sync = true;
+
+        if (needs_sync) {
+            cudaEventRecord(event, stream);
+            cudaStreamWaitEvent(compute_stream, event, 0);
+        }
+    }
     
     char* get_pool() { return d_pool; }
     int* get_physical_ids() { return d_physical_ids; }
