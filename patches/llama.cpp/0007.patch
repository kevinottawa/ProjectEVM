+static void ggml_cuda_evm_rewrite_tensor_views(
+        const ggml_tensor * original_src0,
+        EVM::Manager * mgr,
+        ggml_tensor & src0_copy,
+        const ggml_tensor *& src0) {
+    src0_copy = *original_src0;
+    src0_copy.data = mgr->get_pool();
+    src0_copy.buffer = nullptr;
+    src0_copy.ne[2] = mgr->get_capacity();
+    src0 = &src0_copy;
+}
+
+static void ggml_cuda_evm_rewrite_ids_view(
+        const ggml_tensor * original_ids,
+        EVM::Manager * mgr,
+        ggml_tensor & ids_copy,
+        const ggml_tensor *& ids) {
+    ids_copy = *original_ids;
+    ids_copy.data = mgr->get_physical_ids();
+    ids_copy.nb[1] = ids_copy.nb[0] * ids_copy.ne[0];
+    ids_copy.nb[2] = ids_copy.nb[1] * ids_copy.ne[1];
+    ids_copy.nb[3] = ids_copy.nb[2] * ids_copy.ne[2];
+    ids = &ids_copy;
+}
+
+static bool ggml_cuda_evm_remap_mul_mat_id(
+        ggml_backend_cuda_context & ctx,
+        const ggml_tensor *& src0,
+        const ggml_tensor *& ids,
+        ggml_tensor & src0_copy,
+        ggml_tensor & ids_copy) {
+    if (!ggml_cuda_evm_tensor_eligible(src0, ids)) {
+        return false;
+    }
+
+    if (getenv("EVM_DEBUG")) {
+        fprintf(stderr, "EVM: intercepting mul_mat_id experts=%lld ids=[%lld,%lld]\n",
+                (long long) src0->ne[2],
+                ids ? (long long) ids->ne[0] : 0,
+                ids ? (long long) ids->ne[1] : 0);
+        fprintf(stderr,
+                "EVM: src0 name=%s type=%d ne=[%lld,%lld,%lld,%lld] nb=[%zu,%zu,%zu,%zu] ids nb=[%zu,%zu,%zu,%zu]\n",
+                src0->name,
+                (int) src0->type,
+                (long long) src0->ne[0],
+                (long long) src0->ne[1],
+                (long long) src0->ne[2],
+                (long long) src0->ne[3],
+                src0->nb[0],
+                src0->nb[1],
+                src0->nb[2],
+                src0->nb[3],
+                ids->nb[0],
+                ids->nb[1],
+                ids->nb[2],
+                ids->nb[3]);
+    }
+
+    EVM::Manager * mgr = ggml_cuda_evm_get_or_init_manager(src0);
+
+    int count = 0;
+    std::vector<int> h_ids = ggml_cuda_evm_copy_ids_to_host(ctx, ids, count);
+
+    mgr->update_phase(ids->ne[1]);
+    mgr->ensure_experts(h_ids.data(), count, ctx.stream());
+
+    ggml_cuda_evm_rewrite_ids_view(ids, mgr, ids_copy, ids);
+    ggml_cuda_evm_rewrite_tensor_views(src0, mgr, src0_copy, src0);
+    return true;
+}
+
+static bool ggml_cuda_evm_remap_fused_mul_mat_id(
+        ggml_backend_cuda_context & ctx,
+        const ggml_tensor *& up_src0,
+        const ggml_tensor *& gate_src0,
+        const ggml_tensor *& ids,
+        ggml_tensor & up_src0_copy,
+        ggml_tensor & gate_src0_copy,
+        ggml_tensor & ids_copy) {
+    if (!ggml_cuda_evm_fusion_aware_enabled()) {
+        return false;
+    }
+    if (!ggml_cuda_evm_tensor_eligible(up_src0, ids) || !ggml_cuda_evm_tensor_eligible(gate_src0, ids)) {
+        return false;
+    }
+    if (up_src0->ne[2] != gate_src0->ne[2]) {
+        fprintf(stderr, "EVM: fused remap requires gate/up tensors to expose the same logical expert count\n");
+        return false;
+    }
+
+    EVM::Manager * up_mgr = ggml_cuda_evm_get_or_init_manager(up_src0);
+    EVM::Manager * gate_mgr = ggml_cuda_evm_get_or_init_manager(gate_src0);
+
+    int count = 0;
+    std::vector<int> logical_ids = ggml_cuda_evm_copy_ids_to_host(ctx, ids, count);
+
+    up_mgr->update_phase(ids->ne[1]);
+    gate_mgr->update_phase(ids->ne[1]);
+
+    std::unordered_map<int, int> logical_to_physical;
+    logical_to_physical.reserve((size_t) count);
+    for (int i = 0; i < count; ++i) {
+        const int log_id = logical_ids[i];
+        if (log_id < 0) {
+            continue;
+        }
+        if (logical_to_physical.find(log_id) == logical_to_physical.end()) {
+            const int phys_idx = (int) logical_to_physical.size();
+            logical_to_physical.emplace(log_id, phys_idx);
+        }
+    }
+
+    std::vector<int> up_physical_ids(count);
+    std::vector<int> gate_physical_ids(count);
+    up_mgr->ensure_experts_with_fixed_mapping(logical_ids.data(), up_physical_ids.data(), count, logical_to_physical, ctx.stream());
+    gate_mgr->ensure_experts_with_fixed_mapping(logical_ids.data(), gate_physical_ids.data(), count, logical_to_physical, ctx.stream());
+
+    ggml_cuda_evm_rewrite_ids_view(ids, up_mgr, ids_copy, ids);
+    ggml_cuda_evm_rewrite_tensor_views(up_src0, up_mgr, up_src0_copy, up_src0);
+    ggml_cuda_evm_rewrite_tensor_views(gate_src0, gate_mgr, gate_src0_copy, gate_src0);
+
+    if (getenv("EVM_DEBUG")) {
+        fprintf(stderr,
+                "EVM: fused remap gate/up experts=%lld unique=%zu capacity(up/gate)=%d/%d\n",
+                (long long) up_src0_copy.ne[2],
+                logical_to_physical.size(),
+                up_mgr->get_capacity(),
+                gate_mgr->get_capacity());
     }
+    return true;
+}
