+static std::vector<int> ggml_cuda_evm_copy_ids_to_host(
+        ggml_backend_cuda_context & ctx,
+        const ggml_tensor * ids,
+        int & count) {
+    count = (int) (ids->ne[0] * ids->ne[1]);
+    std::vector<int> h_ids(count);
+    if (ids->nb[1] == ids->ne[0] * (int64_t) sizeof(int)) {
+        CUDA_CHECK(cudaMemcpyAsync(h_ids.data(), ids->data, (size_t) count * sizeof(int), cudaMemcpyDeviceToHost, ctx.stream()));
+    } else {
+        CUDA_CHECK(cudaMemcpy2DAsync(
+                h_ids.data(), ids->ne[0] * sizeof(int),
+                ids->data, ids->nb[1],
+                ids->ne[0] * sizeof(int), ids->ne[1],
+                cudaMemcpyDeviceToHost, ctx.stream()));
+    }
+    CUDA_CHECK(cudaStreamSynchronize(ctx.stream()));
+    return h_ids;
+}
