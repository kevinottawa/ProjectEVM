 namespace EVM {
 
+struct VaultSlice {
+    uint64_t offset = 0;
+    size_t bytes = 0;
+};
+
+class VaultRegistry {
+private:
+    bool attempted = false;
+    bool available = false;
+    std::unordered_map<std::string, std::vector<VaultSlice>> slices;
+#if defined(_WIN32)
+    HANDLE file = INVALID_HANDLE_VALUE;
+    HANDLE mapping = nullptr;
+    char * base = nullptr;
+    uint64_t size = 0;
+#endif
+
+    void load() {
+        attempted = true;
+        const char * index_path = getenv("EVM_EXPERT_VAULT_INDEX");
+        const char * pack_path = getenv("EVM_EXPERT_VAULT_PACK");
+        if (!index_path || !*index_path || !pack_path || !*pack_path) {
+            return;
+        }
+#if !defined(_WIN32)
+        fprintf(stderr, "EVM: external expert vault is currently implemented for Windows builds only\n");
+        return;
+#else
+        std::ifstream index(index_path);
+        if (!index) {
+            fprintf(stderr, "EVM: unable to open expert vault index: %s\n", index_path);
+            return;
+        }
+        std::string line;
+        while (std::getline(index, line)) {
+            if (line.empty() || line[0] == '#') {
+                continue;
+            }
+            std::istringstream fields(line);
+            std::string tensor;
+            std::string text;
+            if (!std::getline(fields, tensor, '\t') || !std::getline(fields, text, '\t')) {
+                fprintf(stderr, "EVM: malformed expert vault index\n");
+                return;
+            }
+            const int expert = std::stoi(text);
+            if (!std::getline(fields, text, '\t')) return;
+            const uint64_t offset = std::stoull(text);
+            if (!std::getline(fields, text, '\t')) return;
+            const size_t bytes = (size_t) std::stoull(text);
+            if (expert < 0) {
+                fprintf(stderr, "EVM: invalid expert ID in vault index\n");
+                return;
+            }
+            auto & tensor_slices = slices[tensor];
+            if (tensor_slices.size() <= (size_t) expert) {
+                tensor_slices.resize((size_t) expert + 1);
+            }
+            if (tensor_slices[expert].bytes != 0) {
+                fprintf(stderr, "EVM: duplicate expert vault index entry for %s/%d\n", tensor.c_str(), expert);
+                return;
+            }
+            tensor_slices[expert] = { offset, bytes };
+        }
+        file = CreateFileA(pack_path, GENERIC_READ, FILE_SHARE_READ, nullptr, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, nullptr);
+        if (file == INVALID_HANDLE_VALUE) {
+            fprintf(stderr, "EVM: unable to open expert vault pack: %s\n", pack_path);
+            return;
+        }
+        LARGE_INTEGER pack_size{};
+        if (!GetFileSizeEx(file, &pack_size)) {
+            fprintf(stderr, "EVM: unable to read expert vault pack size\n");
+            return;
+        }
+        size = (uint64_t) pack_size.QuadPart;
+        mapping = CreateFileMappingA(file, nullptr, PAGE_READONLY, 0, 0, nullptr);
+        if (!mapping) {
+            fprintf(stderr, "EVM: unable to map expert vault pack\n");
+            return;
+        }
+        base = (char *) MapViewOfFile(mapping, FILE_MAP_READ, 0, 0, 0);
+        if (!base) {
+            fprintf(stderr, "EVM: unable to view expert vault pack\n");
+            return;
+        }
+        available = true;
+        fprintf(stderr, "EVM: external expert vault active: tensors=%zu, pack=%.2f GB\n",
+                slices.size(), (double) size / (1024.0 * 1024.0 * 1024.0));
+#endif
+    }
+
+public:
+    ~VaultRegistry() {
+#if defined(_WIN32)
+        if (base) UnmapViewOfFile(base);
+        if (mapping) CloseHandle(mapping);
+        if (file != INVALID_HANDLE_VALUE) CloseHandle(file);
+#endif
+    }
+
+    bool has_tensor(const char * tensor, int expert_count, size_t bytes_per_expert) {
+        if (!attempted) load();
+        if (!available) return false;
+        const auto it = slices.find(tensor);
+        if (it == slices.end() || it->second.size() != (size_t) expert_count) return false;
+        for (const VaultSlice & slice : it->second) {
+            if (slice.bytes != bytes_per_expert || slice.offset > size || slice.bytes > size - slice.offset) return false;
+        }
+        return true;
+    }
+
+    const char * expert_data(const std::string & tensor, int expert, size_t bytes_per_expert) {
+        const auto it = slices.find(tensor);
+        if (!available || it == slices.end() || expert < 0 || (size_t) expert >= it->second.size()) {
+            fprintf(stderr, "EVM: missing external expert vault slice for %s/%d\n", tensor.c_str(), expert);
+            abort();
+        }
+        const VaultSlice & slice = it->second[(size_t) expert];
+        if (slice.bytes != bytes_per_expert || slice.offset > size || slice.bytes > size - slice.offset) {
+            fprintf(stderr, "EVM: invalid external expert vault slice for %s/%d\n", tensor.c_str(), expert);
+            abort();
+        }
+#if defined(_WIN32)
+        return base + slice.offset;
+#else
+        return nullptr;
+#endif
+    }
+};
+
+inline VaultRegistry & vault_registry() {
+    static VaultRegistry registry;
+    return registry;
+}
