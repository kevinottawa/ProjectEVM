 static const size_t kiB = 1024;
 static const size_t MiB = 1024*kiB;
 static const size_t GiB = 1024*MiB;
 
+struct evm_vault_tensor_meta {
+    ggml_type type;
+    std::array<int64_t, GGML_MAX_DIMS> ne;
+};
+
+static const std::unordered_map<std::string, evm_vault_tensor_meta> & evm_vault_tensor_metadata() {
+    static std::once_flag once;
+    static std::unordered_map<std::string, evm_vault_tensor_meta> metadata;
+    std::call_once(once, [] {
+        const char * index_path = getenv("EVM_EXPERT_VAULT_INDEX");
+        if (!index_path || !*index_path) {
+            return;
+        }
+        std::ifstream index(index_path);
+        if (!index) {
+            throw std::runtime_error(format("unable to open EVM expert vault index: %s", index_path));
+        }
+        std::string line;
+        while (std::getline(index, line)) {
+            if (line.empty() || line[0] == '#') {
+                continue;
+            }
+            std::istringstream fields(line);
+            std::string name;
+            std::string expert;
+            std::string offset;
+            std::string bytes;
+            std::string type_text;
+            if (!std::getline(fields, name, '\t') ||
+                !std::getline(fields, expert, '\t') ||
+                !std::getline(fields, offset, '\t') ||
+                !std::getline(fields, bytes, '\t') ||
+                !std::getline(fields, type_text, '\t')) {
+                throw std::runtime_error(format("malformed EVM expert vault index row: %s", line.c_str()));
+            }
+            const int type = std::stoi(type_text);
+            if (type < 0 || type >= GGML_TYPE_COUNT) {
+                throw std::runtime_error(format("invalid GGML type in EVM expert vault index: %d", type));
+            }
+            evm_vault_tensor_meta entry{ static_cast<ggml_type>(type), { 1, 1, 1, 1 } };
+            std::string dim;
+            for (size_t i = 0; i < GGML_MAX_DIMS; ++i) {
