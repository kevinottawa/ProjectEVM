+            if (!inserted && (it->second.type != entry.type || it->second.ne != entry.ne)) {
+                throw std::runtime_error(format("inconsistent EVM expert vault metadata for %s", name.c_str()));
+            }
+        }
+        if (metadata.empty()) {
+            throw std::runtime_error("EVM expert vault index contains no expert tensors");
+        }
+    });
+    return metadata;
+}
