diff --git a/examples/evm-vault-parity/evm-vault-parity.cpp b/examples/evm-vault-parity/evm-vault-parity.cpp
new file mode 100644
index 000000000..c160d6388
--- /dev/null
+++ b/examples/evm-vault-parity/evm-vault-parity.cpp
@@ -0,0 +1,94 @@
+#include "llama.h"
+
+#include <cstdint>
+#include <cstdio>
+#include <cstring>
+#include <string>
+#include <vector>
+
+static bool get_value(int argc, char ** argv, const char * flag, std::string & value) {
+    for (int i = 1; i + 1 < argc; ++i) {
+        if (std::strcmp(argv[i], flag) == 0) {
+            value = argv[i + 1];
+            return true;
+        }
+    }
+    return false;
+}
+
+static uint64_t fnv1a_token(uint64_t hash, llama_token token) {
+    const uint32_t value = static_cast<uint32_t>(token);
+    for (int byte = 0; byte < 4; ++byte) {
+        hash ^= (value >> (byte * 8)) & 0xffU;
+        hash *= 1099511628211ULL;
+    }
+    return hash;
+}
+
+int main(int argc, char ** argv) {
+    std::string model_path;
+    std::string prompt = "EVM exact vault parity probe.";
+    std::string value;
+    int n_predict = 8;
+    int n_ctx = 256;
+    int n_gpu_layers = 99;
+
+    if (!get_value(argc, argv, "-m", model_path)) {
+        std::fprintf(stderr, "missing -m model.gguf\n");
+        return 2;
+    }
+    if (get_value(argc, argv, "-p", value)) prompt = value;
+    if (get_value(argc, argv, "-n", value)) n_predict = std::stoi(value);
+    if (get_value(argc, argv, "-c", value)) n_ctx = std::stoi(value);
+    if (get_value(argc, argv, "-ngl", value)) n_gpu_layers = std::stoi(value);
+
+    llama_backend_init();
+    llama_model_params model_params = llama_model_default_params();
+    model_params.n_gpu_layers = n_gpu_layers;
+    llama_model * model = llama_model_load_from_file(model_path.c_str(), model_params);
+    if (!model) return 3;
+
+    const llama_vocab * vocab = llama_model_get_vocab(model);
+    const int n_prompt = -llama_tokenize(vocab, prompt.c_str(), static_cast<int32_t>(prompt.size()), nullptr, 0, true, true);
+    if (n_prompt <= 0 || n_prompt + n_predict > n_ctx) return 4;
+    std::vector<llama_token> tokens(n_prompt);
+    if (llama_tokenize(vocab, prompt.c_str(), static_cast<int32_t>(prompt.size()), tokens.data(), n_prompt, true, true) < 0) return 5;
+
+    llama_context_params context_params = llama_context_default_params();
+    context_params.n_ctx = n_ctx;
+    context_params.n_batch = 1;
+    context_params.no_perf = true;
+    llama_context * context = llama_init_from_model(model, context_params);
+    if (!context) return 6;
+
+    auto sampler_params = llama_sampler_chain_default_params();
+    sampler_params.no_perf = true;
+    llama_sampler * sampler = llama_sampler_chain_init(sampler_params);
+    llama_sampler_chain_add(sampler, llama_sampler_init_greedy());
+
+    for (llama_token prompt_token : tokens) {
+        llama_batch prompt_batch = llama_batch_get_one(&prompt_token, 1);
+        if (llama_decode(context, prompt_batch) != 0) return 7;
+    }
+
+    llama_token first_token = llama_sampler_sample(sampler, context, -1);
+    llama_batch batch = llama_batch_get_one(&first_token, 1);
+    uint64_t fingerprint = 1469598103934665603ULL;
+    int generated = 0;
+    for (int step = 0; step < n_predict; ++step) {
+        llama_token token = step == 0 ? first_token : llama_sampler_sample(sampler, context, -1);
+        if (llama_vocab_is_eog(vocab, token)) break;
+        fingerprint = fnv1a_token(fingerprint, token);
+        llama_sampler_accept(sampler, token);
+        batch = llama_batch_get_one(&token, 1);
+        ++generated;
+        if (step + 1 < n_predict && llama_decode(context, batch) != 0) break;
+    }
+
+    std::printf("{\"tokens_generated\":%d,\"token_fingerprint_fnv1a64\":\"%016llx\"}\n", generated, static_cast<unsigned long long>(fingerprint));
+    llama_sampler_free(sampler);
+    llama_free(context);
+    llama_model_free(model);
+    llama_backend_free();
+    return generated == n_predict ? 0 : 7;
+}
