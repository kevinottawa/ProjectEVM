Subject: [PATCH 17/26] Add masked routing for GPU expert packs

---
 ggml/src/ggml-cuda/evm.cuh |   7 +++
 src/llama-graph.cpp        | 109 +++++++++++++++++++++++++++++++++++--
 src/llama-graph.h          |  13 +++++
 3 files changed, 125 insertions(+), 4 deletions(-)

diff --git a/ggml/src/ggml-cuda/evm.cuh b/ggml/src/ggml-cuda/evm.cuh
index f455b8577..e39219d72 100644
--- a/ggml/src/ggml-cuda/evm.cuh
+++ b/ggml/src/ggml-cuda/evm.cuh
@@ -643,6 +643,13 @@ public:
                 }
                 expert_access_counts[(size_t) logical_ids[i]]++;
                 if (ability_pack_only && pinned_experts.find(logical_ids[i]) == pinned_experts.end()) {
+                    const char * router_mask = getenv("EVM_ROUTER_MASK_UNAVAILABLE");
+                    if (router_mask && atoi(router_mask) != 0) {
+                        fprintf(stderr,
+                                "EVM: router selected unavailable pack expert %d; router mask was not applied\n",
+                                logical_ids[i]);
+                        abort();
+                    }
                     logical_ids[i] = ability_experts[(size_t) logical_ids[i] % ability_experts.size()];
                     metric_pack_substitutions++;
                 }
diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index d461ffe65..3fa545a22 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -16,11 +16,75 @@
 #include <cassert>
 #include <cmath>
 #include <cstring>
+#include <fstream>
+#include <limits>
 #include <numeric>
 #include <sstream>
 #include <string>
+#include <unordered_map>
 #include <unordered_set>
 
+static bool evm_router_mask_enabled() {
+    const char * enabled = getenv("EVM_ROUTER_MASK_UNAVAILABLE");
+    const char * pack_only = getenv("EVM_ABILITY_PACK_ONLY");
+    return enabled && atoi(enabled) != 0 && pack_only && atoi(pack_only) != 0;
+}
+
+static std::vector<float> evm_router_mask_for_layer(int il, int64_t n_expert, int64_t n_expert_used) {
+    if (!evm_router_mask_enabled()) {
+        return {};
+    }
+
+    const char * index_path = getenv("EVM_ABILITY_PACK_INDEX");
+    if (!index_path || !*index_path) {
+        GGML_ABORT("EVM router mask requires EVM_ABILITY_PACK_INDEX");
+    }
+
+    static std::string loaded_path;
+    static std::unordered_map<int, std::unordered_set<int>> experts_by_layer;
+    if (loaded_path != index_path) {
+        std::ifstream index(index_path);
+        if (!index) {
+            GGML_ABORT("failed to open EVM ability-pack index: %s", index_path);
+        }
+
+        loaded_path = index_path;
+        experts_by_layer.clear();
+        std::string line;
+        while (std::getline(index, line)) {
+            if (line.empty() || line[0] == '#') {
+                continue;
+            }
+            std::istringstream fields(line);
+            std::string tensor_name;
+            int expert = -1;
+            if (!std::getline(fields, tensor_name, '\t') || !(fields >> expert)) {
+                continue;
+            }
+            const auto begin = tensor_name.find("blk.");
+            const auto end = tensor_name.find('.', begin == std::string::npos ? 0 : begin + 4);
+            if (begin == std::string::npos || end == std::string::npos) {
+                continue;
+            }
+            const int layer = std::stoi(tensor_name.substr(begin + 4, end - begin - 4));
+            experts_by_layer[layer].insert(expert);
+        }
+    }
+
+    const auto found = experts_by_layer.find(il);
+    if (found == experts_by_layer.end() || (int64_t) found->second.size() < n_expert_used) {
+        GGML_ABORT("EVM ability pack layer %d provides fewer than %lld experts required by the router", il, (long long) n_expert_used);
+    }
+
+    std::vector<float> mask(n_expert, -std::numeric_limits<float>::infinity());
+    for (const int expert : found->second) {
+        if (expert >= 0 && expert < n_expert) {
+            mask[expert] = 0.0f;
+        }
+    }
+    return mask;
+}
+
 // dedup helpers
 
 static ggml_tensor * build_attn_inp_kq_mask(
@@ -1170,6 +1234,18 @@ bool llm_graph_input_sampling::can_reuse(const llm_graph_params & params) {
     return true;
 }
 
+void llm_graph_input_expert_mask::set_input(const llama_ubatch * ubatch) {
+    GGML_UNUSED(ubatch);
+    GGML_ASSERT(mask);
+    GGML_ASSERT(ggml_backend_buffer_is_host(mask->buffer));
+    memcpy(mask->data, values.data(), values.size()*sizeof(float));
+}
+
+bool llm_graph_input_expert_mask::can_reuse(const llm_graph_params & params) {
+    GGML_UNUSED(params);
+    return true;
+}
+
 //
 // llm_graph_result
 //
@@ -1880,6 +1956,25 @@ ggml_tensor * llm_graph_context::build_moe_ffn(
         cb(selection_probs, "ffn_moe_probs_biased", il);
     }
 
+    // EVM pack-only mode must constrain routing before top-k selection.  The
+    // legacy CUDA-side fallback remapped an already-selected missing expert,
+    // which preserved an invalid router weight.  Masking here makes the normal
+    // graph select only installed experts and lets the existing normalization
+    // renormalize their retained weights.
+    ggml_tensor * router_mask = nullptr;
+    const auto router_mask_values = evm_router_mask_for_layer(il, n_expert, n_expert_used);
+    if (!router_mask_values.empty()) {
+        auto input = std::make_unique<llm_graph_input_expert_mask>(router_mask_values);
+        input->mask = ggml_new_tensor_1d(ctx0, GGML_TYPE_F32, n_expert);
+        ggml_set_input(input->mask);
+        router_mask = input->mask;
+        res->add_input(std::move(input));
+
+        const auto router_mask_2d = ggml_repeat(ctx0, router_mask, selection_probs);
+        selection_probs = ggml_add(ctx0, selection_probs, router_mask_2d);
+        cb(selection_probs, "ffn_moe_probs_evm_pack_masked", il);
+    }
+
     // select top n_group_used expert groups
     // https://huggingface.co/deepseek-ai/DeepSeek-V3/blob/e815299b0bcbac849fa540c768ef21845365c9eb/modeling_deepseek.py#L440-L457
     if (hparams.n_expert_groups > 1 && n_tokens > 0) {
@@ -1913,16 +2008,22 @@ ggml_tensor * llm_graph_context::build_moe_ffn(
     }
     cb(selected_experts, "ffn_moe_topk", il);
 
+    ggml_tensor * weight_probs = probs;
+    if (router_mask != nullptr) {
+        weight_probs = ggml_add(ctx0, probs, ggml_repeat(ctx0, router_mask, probs));
+        cb(weight_probs, "ffn_moe_weights_evm_pack_masked", il);
+    }
+
     if (arch == LLM_ARCH_GROVEMOE && n_expert != hparams.n_expert) {
         // TODO: Use scalar div instead when/if implemented
         ggml_tensor * f_sel = ggml_cast(ctx0, selected_experts, GGML_TYPE_F32);
         selected_experts = ggml_cast(ctx0, ggml_scale(ctx0, f_sel, 1.0f / float(hparams.n_group_experts)), GGML_TYPE_I32);
-        probs = ggml_reshape_3d(ctx0, probs, 1, hparams.n_expert, n_tokens);
+        weight_probs = ggml_reshape_3d(ctx0, weight_probs, 1, hparams.n_expert, n_tokens);
     } else {
-        probs = ggml_reshape_3d(ctx0, probs, 1, n_expert, n_tokens);
+        weight_probs = ggml_reshape_3d(ctx0, weight_probs, 1, n_expert, n_tokens);
     }
 
-    ggml_tensor * weights = ggml_get_rows(ctx0, probs, selected_experts); // [1, n_expert_used, n_tokens]
+    ggml_tensor * weights = ggml_get_rows(ctx0, weight_probs, selected_experts); // [1, n_expert_used, n_tokens]
     cb(weights, "ffn_moe_weights", il);
 
 
@@ -1933,7 +2034,7 @@ ggml_tensor * llm_graph_context::build_moe_ffn(
         cb(weights, "ffn_moe_weights_softmax", il);
     }
 
-    if (norm_w) {
+    if (norm_w || router_mask != nullptr) {
         weights = ggml_reshape_2d(ctx0, weights, n_expert_used, n_tokens);
 
         ggml_tensor * weights_sum = ggml_sum_rows(ctx0, weights); // [1, n_tokens]
diff --git a/src/llama-graph.h b/src/llama-graph.h
index 4b5b75c63..15316483c 100644
--- a/src/llama-graph.h
+++ b/src/llama-graph.h
@@ -645,6 +645,19 @@ public:
     std::map<llama_seq_id, llama_sampler *> samplers;
 };
 
+// Static per-layer router mask used by the optional EVM GPU expert-pack mode.
+class llm_graph_input_expert_mask : public llm_graph_input_i {
+public:
+    explicit llm_graph_input_expert_mask(std::vector<float> values) : values(std::move(values)) { }
+    virtual ~llm_graph_input_expert_mask() = default;
+
+    void set_input(const llama_ubatch * ubatch) override;
+    bool can_reuse(const llm_graph_params & params) override;
+
+    ggml_tensor * mask = nullptr;
+    const std::vector<float> values;
+};
+
