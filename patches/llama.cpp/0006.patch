From 1ba954580c63a4e6601e2be3803de0d80c2816ad Mon Sep 17 00:00:00 2001
From: kevinottawa <69475646+kevinottawa@users.noreply.github.com>
Date: Thu, 9 Jul 2026 21:24:38 -0400
Subject: [PATCH 06/26] Disable CUDA fusion for EVM remap safety

---
 ggml/src/ggml-cuda/ggml-cuda.cu |  4 +++-
 ggml/src/ggml-cuda/mmvq.cu      | 20 +++++++++++++++++++-
 2 files changed, 22 insertions(+), 2 deletions(-)

diff --git a/ggml/src/ggml-cuda/ggml-cuda.cu b/ggml/src/ggml-cuda/ggml-cuda.cu
index adc412af2..9baff5eeb 100644
--- a/ggml/src/ggml-cuda/ggml-cuda.cu
+++ b/ggml/src/ggml-cuda/ggml-cuda.cu
@@ -3157,7 +3157,9 @@ static bool ggml_cuda_can_fuse(const struct ggml_cgraph *                cgraph,
 static int ggml_cuda_try_fuse(ggml_backend_cuda_context * cuda_ctx, ggml_cgraph * cgraph, int i) {
 
     static bool disable_fusion = getenv("GGML_CUDA_DISABLE_FUSION") != nullptr && std::atoi(getenv("GGML_CUDA_DISABLE_FUSION"));
-    if (disable_fusion) {
+    static bool disable_fusion_for_evm = getenv("EVM_DISABLE") == nullptr &&
+        (getenv("EVM_CPU_BACKING") != nullptr || getenv("EVM_CUDA_STREAMING") != nullptr || getenv("EVM_CAPACITY_PCT") != nullptr);
+    if (disable_fusion || disable_fusion_for_evm) {
         return 0;
     }
 
diff --git a/ggml/src/ggml-cuda/mmvq.cu b/ggml/src/ggml-cuda/mmvq.cu
index 9cb510158..c67428ffc 100644
--- a/ggml/src/ggml-cuda/mmvq.cu
+++ b/ggml/src/ggml-cuda/mmvq.cu
@@ -729,7 +729,9 @@ static __global__ void mul_mat_vec_q_moe(
 
 #pragma unroll
         for (int i = 0; i < c_rows_per_block; ++i) {
-            tmp[i] += vec_dot_q_cuda(vx, &y[kby], kbx_offset + i*stride_row_x + kbx, kqs);
+            if (c_rows_per_block == 1 || uint32_t(row0 + i) < nrows_x) {
+                tmp[i] += vec_dot_q_cuda(vx, &y[kby], kbx_offset + i*stride_row_x + kbx, kqs);
+            }
         }
     }
 
@@ -1191,7 +1193,19 @@ void ggml_cuda_mul_mat_vec_q(
         const int64_t s11 = src1->nb[1] / ts_src1;
         const int64_t s12 = src1->nb[2] / ts_src1;
         const int64_t s13 = src1->nb[3] / ts_src1;
+        if (ids && getenv("EVM_DEBUG")) {
+            fprintf(stderr,
+                    "EVM: mmvq quantize src1 type=%d src0_ne=[%lld,%lld,%lld,%lld] src1_ne=[%lld,%lld,%lld,%lld] dst_ne=[%lld,%lld,%lld,%lld]\n",
+                    (int) src0->type,
+                    (long long) src0->ne[0], (long long) src0->ne[1], (long long) src0->ne[2], (long long) src0->ne[3],
+                    (long long) src1->ne[0], (long long) src1->ne[1], (long long) src1->ne[2], (long long) src1->ne[3],
+                    (long long) dst->ne[0], (long long) dst->ne[1], (long long) dst->ne[2], (long long) dst->ne[3]);
+        }
         quantize_row_q8_1_cuda(src1_d, nullptr, src1_q8_1.get(), src0->type, ne10, s11, s12, s13, ne10_padded, ne11, ne12, ne13, stream);
+        if (ids && getenv("EVM_DEBUG_SYNC")) {
+            CUDA_CHECK(cudaStreamSynchronize(stream));
+            fprintf(stderr, "EVM: mmvq quantize complete type=%d\n", (int) src0->type);
+        }
     }
 
     const int64_t s01 = src0->nb[1] / ts_src0;
@@ -1221,6 +1235,10 @@ void ggml_cuda_mul_mat_vec_q(
         ne01,              ncols_dst,     s01, stride_col_y,     stride_col_dst,
         ne02, nchannels_y, nchannels_dst, s02, stride_channel_y, stride_channel_dst,
         ne03,              ne3,           s03, s13,              s3,               ids_stride, stream);
+    if (ids && getenv("EVM_DEBUG_SYNC")) {
+        CUDA_CHECK(cudaStreamSynchronize(stream));
+        fprintf(stderr, "EVM: mmvq complete type=%d\n", (int) src0->type);
+    }
 }
 
 void ggml_cuda_op_mul_mat_vec_q(
-- 
2.43.0.windows.1

