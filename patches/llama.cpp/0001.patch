diff --git a/ggml/src/ggml-cuda/evm.cuh b/ggml/src/ggml-cuda/evm.cuh
new file mode 100644
index 000000000..36246e1e0
--- /dev/null
+++ b/ggml/src/ggml-cuda/evm.cuh
@@ -0,0 +1,370 @@
+#pragma once
+
+#include "ggml-cuda.h"
+#include <cuda_runtime.h>
+#include <unordered_map>
+#include <unordered_set>
+#include <vector>
+#include <list>
+#include <mutex>
+#include <cstdio>
+#include <memory>
+#include <algorithm>
+#include <cstdlib>
+
+namespace EVM {
+
+struct CacheSlot {
+    int physical_index;
+    int logical_expert_id;
+};
+
+class Manager {
+private:
+    int capacity = 0;
+    int requested_capacity = 0;
+    int budget_max_capacity = 0;
+    int total_experts = 0;
+    int expert_size_bytes = 0;
+    
+    char* d_pool = nullptr;
+    char* h_experts_mmap = nullptr;
+    int* d_physical_ids = nullptr;
+    bool source_on_device = false;
+    
+    cudaStream_t stream;
+    cudaEvent_t event;
+    
+    std::unordered_map<int, std::list<int>::iterator> cache_map;
+    std::list<int> lru_list;
+    std::vector<CacheSlot> slots;
+    
+    bool initialized = false;
+    bool strict_budget = false;
+    std::mutex mtx;
+
+    static long long read_env_ll(const char * name, long long default_value = 0) {
+        const char * env = getenv(name);
+        if (!env || !*env) {
+            return default_value;
+        }
+        char * end = nullptr;
+        const long long value = strtoll(env, &end, 10);
+        return end == env ? default_value : value;
+    }
+
+public:
+    uint64_t metric_cache_hits = 0;
+    uint64_t metric_cache_misses = 0;
+    uint64_t metric_bytes_transferred = 0;
+    uint64_t metric_evictions = 0;
+
+public:
+    Manager() {}
+    ~Manager() {
+        if (initialized) {
+            uint64_t total = metric_cache_hits + metric_cache_misses;
+            if (total > 0) {
+                fprintf(stderr, "\n[EVM Metrics]\n");
+                fprintf(stderr, "Cache Hits       : %llu\n", (unsigned long long)metric_cache_hits);
+                fprintf(stderr, "Cache Misses     : %llu\n", (unsigned long long)metric_cache_misses);
+                fprintf(stderr, "Evictions        : %llu\n", (unsigned long long)metric_evictions);
+                fprintf(stderr, "Bytes Transferred: %llu (%.2f MB)\n", (unsigned long long)metric_bytes_transferred, (double)metric_bytes_transferred / (1024*1024));
+                fprintf(stderr, "Hit Rate         : %.2f%%\n", 100.0 * metric_cache_hits / total);
+                fflush(stderr);
+            }
+            cudaStreamDestroy(stream);
+            cudaEventDestroy(event);
+        }
+        if (d_pool) cudaFree(d_pool);
+        if (d_physical_ids) cudaFree(d_physical_ids);
+    }
+
+    void reset_cache_state() {
+        cache_map.clear();
+        lru_list.clear();
+        slots.clear();
+        for (int i = 0; i < capacity; ++i) {
+            slots.push_back({i, -1});
+            lru_list.push_front(i);
+        }
+    }
+
+    void resize_pool_locked(int new_capacity) {
+        const int requested = std::max(1, std::min(new_capacity, total_experts));
+        if (strict_budget && budget_max_capacity > 0 && requested > budget_max_capacity) {
+            fprintf(stderr,
+                    "EVM: strict budget exceeded: requested %d experts, budget allows %d. "
+                    "Increase EVM_EXPERT_POOL_MB/EVM_CUDA_FREE_RESERVE_MB or reduce prefill batch size.\n",
+                    requested, budget_max_capacity);
+            abort();
+        }
+
+        new_capacity = requested;
+        if (new_capacity == capacity && d_pool != nullptr) {
+            return;
+        }
+
+        char * new_pool = nullptr;
+        CUDA_CHECK(cudaMalloc(&new_pool, (size_t)new_capacity * expert_size_bytes));
+        if (d_pool) {
+            cudaFree(d_pool);
+        }
+        d_pool = new_pool;
+        capacity = new_capacity;
+        reset_cache_state();
+    }
+
+public:
+    void init(int num_experts_capacity, int bytes_per_expert, char* original_d_ptr, int num_total_experts) {
+        std::lock_guard<std::mutex> lock(mtx);
+        if (initialized) return;
+        
+        total_experts = num_total_experts;
+        expert_size_bytes = bytes_per_expert;
+        strict_budget = read_env_ll("EVM_STRICT_BUDGET", 0) != 0;
+
+        budget_max_capacity = total_experts;
+        const long long pool_mb = read_env_ll("EVM_EXPERT_POOL_MB", 0);
+        if (pool_mb > 0) {
+            const long long pool_bytes = pool_mb * 1024LL * 1024LL;
+            const int cap_by_pool = (int) (pool_bytes / std::max(1, expert_size_bytes));
+            budget_max_capacity = std::max(1, std::min(budget_max_capacity, cap_by_pool));
+        }
+
+        const long long reserve_mb = read_env_ll("EVM_CUDA_FREE_RESERVE_MB", 0);
+        if (reserve_mb > 0) {
+            size_t free_bytes = 0;
+            size_t total_bytes = 0;
+            if (cudaMemGetInfo(&free_bytes, &total_bytes) == cudaSuccess) {
+                const long long reserve_bytes = reserve_mb * 1024LL * 1024LL;
+                const long long usable_bytes = (long long) free_bytes - reserve_bytes;
+                const int cap_by_free = usable_bytes > 0 ? (int) (usable_bytes / std::max(1, expert_size_bytes)) : 0;
+                budget_max_capacity = std::max(1, std::min(budget_max_capacity, cap_by_free));
+            } else {
+                cudaGetLastError();
+            }
+        }
+
+        requested_capacity = std::max(1, std::min(num_experts_capacity, total_experts));
+        if (budget_max_capacity > 0) {
+            requested_capacity = std::min(requested_capacity, budget_max_capacity);
+        }
+        capacity = requested_capacity;
+        CUDA_CHECK(cudaMalloc(&d_pool, (size_t)capacity * expert_size_bytes));
+        CUDA_CHECK(cudaMalloc(&d_physical_ids, 65536 * sizeof(int))); // Max 65536 ids for large batches
+        CUDA_CHECK(cudaMemset(d_physical_ids, 0, 65536 * sizeof(int)));
+
+        h_experts_mmap = original_d_ptr;
+        cudaPointerAttributes attr;
+        cudaError_t attr_status = cudaPointerGetAttributes(&attr, original_d_ptr);
+        if (attr_status == cudaSuccess) {
+#if CUDART_VERSION >= 10000
+            source_on_device = attr.type == cudaMemoryTypeDevice;
+#else
+            source_on_device = attr.memoryType == cudaMemoryTypeDevice;
+#endif
+        } else {
+            cudaGetLastError();
+            source_on_device = false;
+        }
+        
+        cudaStreamCreateWithFlags(&stream, cudaStreamNonBlocking);
+        cudaEventCreate(&event);
+        
+        reset_cache_state();
+        
+        initialized = true;
+
+        if (pool_mb > 0 || reserve_mb > 0 || strict_budget) {
+            fprintf(stderr,
+                    "EVM: budget controls active: requested_capacity=%d, budget_max_capacity=%d, "
+                    "expert_size=%.2f MB, strict=%d\n",
+                    requested_capacity,
+                    budget_max_capacity,
+                    (double) expert_size_bytes / (1024.0 * 1024.0),
+                    strict_budget ? 1 : 0);
+        }
+    }
+    
+    bool is_initialized() const { return initialized; }
+    int get_capacity() const { return capacity; }
+
+    void update_phase(int batch_size) {
+        if (!is_initialized()) return;
+        std::lock_guard<std::mutex> lock(mtx);
+
+        int threshold = 1;
+        if (const char * env = getenv("EVM_PREFILL_BATCH_THRESHOLD")) {
+            threshold = std::max(1, atoi(env));
+        }
+
+        const int target_capacity = batch_size > threshold ? total_experts : requested_capacity;
+        resize_pool_locked(target_capacity);
+    }
+
+    void ensure_experts(int* logical_ids, int count, cudaStream_t compute_stream) {
+        if (!is_initialized()) return;
+        std::lock_guard<std::mutex> lock(mtx);
+        
+        // CRITICAL RACE CONDITION FIX:
+        // We must wait for the GPU to finish any previous kernels on compute_stream
+        // before we overwrite d_physical_ids or evict any experts from d_pool.
+        CUDA_CHECK(cudaStreamSynchronize(compute_stream));
+        
+        std::unordered_set<int> unique_ids;
+        for (int i = 0; i < count; ++i) {
+            if (logical_ids[i] >= 0) {
+                unique_ids.insert(logical_ids[i]);
+            }
+        }
+        if ((int) unique_ids.size() > capacity) {
+            resize_pool_locked((int) unique_ids.size());
+        }
+
+        bool needs_sync = false;
+        
+        for (int i = 0; i < count; ++i) {
+            int log_id = logical_ids[i];
+            if (log_id < 0) continue;
+            if (log_id >= 2048) {
+                fprintf(stderr, "EVM: ignoring out-of-range logical expert id %d\n", log_id);
+                continue;
+            }
+            
+            auto it = cache_map.find(log_id);
+            if (it != cache_map.end()) {
+                metric_cache_hits++;
+                int phys_idx = *(it->second);
+                lru_list.erase(it->second);
+                lru_list.push_front(phys_idx);
+                cache_map[log_id] = lru_list.begin();
+                logical_ids[i] = phys_idx;
+            } else {
+                metric_cache_misses++;
+                int phys_idx = lru_list.back();
+                lru_list.pop_back();
+                
+                int old_log = slots[phys_idx].logical_expert_id;
+                if (old_log != -1) {
+                    metric_evictions++;
+                    cache_map.erase(old_log);
+                }
+                
+                slots[phys_idx].logical_expert_id = log_id;
+                
+                size_t offset = (size_t)log_id * expert_size_bytes;
+                size_t dst_offset = (size_t)phys_idx * expert_size_bytes;
+                
+                CUDA_CHECK(cudaMemcpyAsync(
+                    d_pool + dst_offset,
+                    h_experts_mmap + offset,
+                    expert_size_bytes,
+                    source_on_device ? cudaMemcpyDeviceToDevice : cudaMemcpyHostToDevice,
+                    stream));
+                metric_bytes_transferred += expert_size_bytes;
+                needs_sync = true;
+                
+                lru_list.push_front(phys_idx);
+                cache_map[log_id] = lru_list.begin();
+                logical_ids[i] = phys_idx;
+            }
+        }
+        
+        // Now it's safe to overwrite d_physical_ids because compute_stream is idle
+        // Use synchronous cudaMemcpy so logical_ids (h_ids vector) doesn't go out of scope!
+        CUDA_CHECK(cudaMemcpy(d_physical_ids, logical_ids, count * sizeof(int), cudaMemcpyHostToDevice));
+        needs_sync = true;
+        
+        if (needs_sync) {
+            cudaEventRecord(event, stream);
+            cudaStreamWaitEvent(compute_stream, event, 0);
+        }
+    }
+    
+    char* get_pool() { return d_pool; }
+    int* get_physical_ids() { return d_physical_ids; }
+};
+
+inline std::unordered_map<const ggml_tensor*, std::shared_ptr<Manager>>& get_managers_map() {
+    static std::unordered_map<const ggml_tensor*, std::shared_ptr<Manager>> managers;
+    return managers;
+}
+inline std::mutex& get_managers_mutex() {
+    static std::mutex mtx;
+    return mtx;
+}
+
+inline void print_all_stats() {
+    auto& managers = get_managers_map();
+    std::lock_guard<std::mutex> lock(get_managers_mutex());
+    uint64_t total_hits = 0;
+    uint64_t total_misses = 0;
+    uint64_t total_evictions = 0;
+    uint64_t total_bytes_transferred = 0;
+
+    for (auto& pair : managers) {
+        if (!pair.second) continue;
+        total_hits += pair.second->metric_cache_hits;
+        total_misses += pair.second->metric_cache_misses;
+        total_evictions += pair.second->metric_evictions;
+        total_bytes_transferred += pair.second->metric_bytes_transferred;
+    }
+
+    const uint64_t total = total_hits + total_misses;
+    if (total == 0) {
+        return;
+    }
+
+    fprintf(stderr, "\n[EVM Metrics]\n");
+    fprintf(stderr, "Cache Hits       : %llu\n", (unsigned long long)total_hits);
+    fprintf(stderr, "Cache Misses     : %llu\n", (unsigned long long)total_misses);
+    fprintf(stderr, "Evictions        : %llu\n", (unsigned long long)total_evictions);
+    fprintf(stderr, "Bytes Transferred: %llu (%.2f MB)\n", (unsigned long long)total_bytes_transferred, (double)total_bytes_transferred / (1024*1024));
+    fprintf(stderr, "Hit Rate         : %.2f%%\n", 100.0 * total_hits / total);
+
+    // Clear counters so later explicit calls and manager destructors do not double-report.
+    for (auto& pair : managers) {
+        if (!pair.second) continue;
+        pair.second->metric_cache_hits = 0;
+        pair.second->metric_cache_misses = 0;
+        pair.second->metric_evictions = 0;
+        pair.second->metric_bytes_transferred = 0;
+    }
+    fflush(stderr);
+}
+
+inline Manager* get_manager(const ggml_tensor* t) {
+    auto& managers = get_managers_map();
+    std::lock_guard<std::mutex> lock(get_managers_mutex());
+    if (managers.find(t) == managers.end()) {
+        static bool atexit_registered = false;
+        if (!atexit_registered) {
+            atexit(print_all_stats);
+            atexit_registered = true;
+        }
+        managers[t] = std::make_shared<Manager>();
+    }
+    return managers[t].get();
+}
+
+struct ShapeSwapper {
+    ggml_tensor* ids;
+    void* original_data;
+    int64_t original_ne2;
+    
+    ShapeSwapper(const ggml_tensor* ids_ptr, void* new_data, int64_t new_ne2 = -1) 
+        : ids(const_cast<ggml_tensor*>(ids_ptr)), original_data(ids_ptr->data), original_ne2(ids_ptr->ne[2]) 
+    {
+        ids->data = new_data;
+        if (new_ne2 > 0) {
+            ids->ne[2] = new_ne2;
+        }
+    }
+    ~ShapeSwapper() {
+        ids->data = original_data;
+        ids->ne[2] = original_ne2;
+    }
+};
+
+} // namespace EVM
diff --git a/ggml/src/ggml-cuda/ggml-cuda.cu b/ggml/src/ggml-cuda/ggml-cuda.cu
index 71cc2a619..3ea493648 100644
--- a/ggml/src/ggml-cuda/ggml-cuda.cu
+++ b/ggml/src/ggml-cuda/ggml-cuda.cu
@@ -1,4 +1,5 @@
 #include "ggml-cuda.h"
+#include <memory>
 #include "ggml-impl.h"
 #include "ggml-backend-impl.h"
 
@@ -24,6 +25,7 @@
 #include "ggml-cuda/cumsum.cuh"
 #include "ggml-cuda/diagmask.cuh"
 #include "ggml-cuda/diag.cuh"
+#include "ggml-cuda/evm.cuh"
 #include "ggml-cuda/fattn.cuh"
 #include "ggml-cuda/fwht.cuh"
 #include "ggml-cuda/getrows.cuh"
@@ -1762,6 +1764,86 @@ static void ggml_cuda_mul_mat_id(ggml_backend_cuda_context & ctx, ggml_tensor *
     GGML_ASSERT(dst->type  == GGML_TYPE_F32);
 
     GGML_TENSOR_BINARY_OP_LOCALS
+    
+    ggml_tensor ids_copy;
+    ggml_tensor src0_copy;
+
+    // EVM Interception: Check if this is an MoE layer
+    static int ignore_count = -1;
+    static int target_count = -1;
+    if (ignore_count == -1) {
+        if (getenv("EVM_IGNORE_EXPERT_COUNT")) {
+            ignore_count = atoi(getenv("EVM_IGNORE_EXPERT_COUNT"));
+        } else {
+            ignore_count = 0;
+        }
+    }
+    if (target_count == -1) {
+        if (getenv("EVM_TARGET_EXPERT_COUNT")) {
+            target_count = atoi(getenv("EVM_TARGET_EXPERT_COUNT"));
+        } else {
+            target_count = 0;
+        }
+    }
+
+    bool evm_eligible = ids && src0->ne[2] > 1 && !getenv("EVM_DISABLE");
+    if (evm_eligible && target_count > 0) {
+        evm_eligible = src0->ne[2] == target_count;
+    } else if (evm_eligible && ignore_count > 0) {
+        evm_eligible = src0->ne[2] != ignore_count;
+    }
+
+    if (evm_eligible) {
+        if (getenv("EVM_DEBUG")) {
+            fprintf(stderr, "EVM: intercepting mul_mat_id experts=%lld ids=[%lld,%lld]\n",
+                    (long long) src0->ne[2],
+                    ids ? (long long) ids->ne[0] : 0,
+                    ids ? (long long) ids->ne[1] : 0);
+        }
+        EVM::Manager* mgr = EVM::get_manager(src0);
