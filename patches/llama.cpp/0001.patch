diff --git a/examples/routing-observatory/routing-observatory.cpp b/examples/routing-observatory/routing-observatory.cpp
new file mode 100644
index 000000000..81784c75b
--- /dev/null
+++ b/examples/routing-observatory/routing-observatory.cpp
@@ -0,0 +1,88 @@
+#include "arg.h"
+#include "common.h"
+#include "llama.h"
+#include <cstdio>
+#include <string>
+#include <vector>
+
+struct observatory_data {
+    FILE * out_file;
+    int prompt_id;
+};
+
+static bool observatory_cb_eval(struct ggml_tensor * t, bool ask, void * user_data) {
+    if (ask) return true;
+    
+    auto * obs = (observatory_data *) user_data;
+    std::string name = t->name;
+    
+    if (name.find("ffn_moe_probs-") == 0) {
+        // Find layer index
+        int il = std::stoi(name.substr(name.find_last_of('-') + 1));
+        
+        bool is_host = ggml_backend_buffer_is_host(t->buffer);
+        std::vector<uint8_t> data;
+        if (!is_host) {
+            auto n_bytes = ggml_nbytes(t);
+            data.resize(n_bytes);
+            ggml_backend_tensor_get(t, data.data(), 0, n_bytes);
+        }
+        float * probs = is_host ? (float*)t->data : (float*)data.data();
+        
+        int n_expert = t->ne[0];
+        int n_tokens = t->ne[1];
+        
+        for (int tok = 0; tok < n_tokens; tok++) {
+            fprintf(obs->out_file, "{\"prompt_id\": %d, \"layer_id\": %d, \"token_idx\": %d, \"probs\": [", obs->prompt_id, il, tok);
+            for (int e = 0; e < n_expert; e++) {
+                fprintf(obs->out_file, "%f%s", probs[tok * n_expert + e], (e == n_expert - 1) ? "" : ", ");
+            }
+            fprintf(obs->out_file, "]}\n");
+        }
+    }
+    return true;
+}
+
+int main(int argc, char ** argv) {
+    common_params params;
+    common_init();
+    if (!common_params_parse(argc, argv, params, LLAMA_EXAMPLE_COMMON)) {
+        return 1;
+    }
+    llama_backend_init();
+    llama_numa_init(params.numa);
+
+    observatory_data obs;
+    obs.prompt_id = params.sampling.seed; // passing prompt_id via seed parameter for simplicity
+    
+    // We append so that running over multiple prompts concatenates the logs
+    obs.out_file = fopen("routing_trace.jsonl", "a");
+    if (!obs.out_file) {
+        fprintf(stderr, "Failed to open routing_trace.jsonl\n");
+        return 1;
+    }
+    
+    params.cb_eval = observatory_cb_eval;
+    params.cb_eval_user_data = &obs;
+    params.warmup = false;
+
+    auto llama_init = common_init_from_params(params);
+    auto * model = llama_init->model();
+    auto * ctx   = llama_init->context();
+
+    if (!model || !ctx) {
+        fprintf(stderr, "Failed to load model\n");
+        return 1;
+    }
+
+    std::vector<llama_token> tokens = common_tokenize(ctx, params.prompt, true, true);
+    
+    if (llama_decode(ctx, llama_batch_get_one(tokens.data(), tokens.size()))) {
+        fprintf(stderr, "Decode failed\n");
+        return 1;
+    }
+    
+    fclose(obs.out_file);
+    llama_backend_free();
+    return 0;
+}
